# Required. Create a bot with BotFather and paste its token here.
TELEGRAM_BOT_TOKEN=

# Required. Set at least one provider key.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional but recommended for OpenAI safety attribution.
# Keep this secret and at least 16 characters long.
SAFETY_IDENTIFIER_SALT=

# Comma-separated numeric Telegram user IDs that can manage the allowlist.
# When set, these owners also restrict chat settings commands.
# Set this before first run to manage the allowlist via Telegram commands.
# Without owners, /togglechat, /toggleuser, and /whitelist are disabled.
BOT_OWNER_USER_IDS=

# Defaults
# Optional. Leave blank to use the first alias from the first configured provider.
# Common choices: o = OpenAI, g = Gemini, c = Claude.
BOT_DEFAULT_MODEL_ALIAS=
BOT_DEFAULT_REPLY_MODE=auto
BOT_SKIP_PREFIX=//
BOT_CONVERSATION_TIMEOUT_SECONDS=300

# Model catalog
# Optional. Leave blank to use ${BOT_DATA_DIR}/models.toml.
# Set this to an operator-managed models.toml when provider model IDs or aliases change.
BOT_MODEL_CONFIG_PATH=

# Storage
# Local runs can keep the default. Docker Compose overrides this to /data.
BOT_DATA_DIR=./data

# Optional prompt override
BOT_SYSTEM_PROMPT=You are a helpful assistant in a Telegram chat. Answer clearly and briefly, keep context local to the active conversation, and avoid assuming you should answer messages that explicitly opt out.
